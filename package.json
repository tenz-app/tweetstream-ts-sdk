  "author": "TweetStream",
  "license": "MIT",
  "homepage": "https://tweetstream.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tenz/tweetstream-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/tenz/tweetstream-ts-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
