{
  "name": "tweetstream-sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for TweetStream - Real-time Twitter/X and Truth Social streaming API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
